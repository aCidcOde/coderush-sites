# [Modulo Infraestrutura SEO SVD]
# @Author: André Gomes ( @acidcode )
# @since 2026-02-10
# Regras SEO para canonicalizacao de host e URL em servidores Apache.

RewriteEngine On

# Canonicaliza host: non-www -> www
RewriteCond %{HTTP_HOST} ^sistemavendadireta\.com\.br$ [NC]
RewriteRule ^(.*)$ https://www.sistemavendadireta.com.br/$1 [R=301,L]

# Remove /index.php da URL para padrao SEO em diretorios
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]
